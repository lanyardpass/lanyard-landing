---
// PostLayout — the blog's shell. Deliberately lighter than GuideLayout: a post
// is a dated piece of writing, not a maintained reference. Header (kicker,
// title, dek, byline + date), optional hero, prose body (shares the guide
// typography via guides.css so the design bar carries over), CTA, Article
// schema. No answer box, no TOC, no FAQ.
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';
import GuideCTA from '@/components/guides/GuideCTA.astro';
import { SITE } from '@/data/site';
import '@/styles/guides.css';

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  dek: string;
  byline: string;
  published: Date;
  updated?: Date;
  hero?: ImageMetadata;
  heroAlt?: string;
  ogImage?: ImageMetadata;
  readingTime: number;
}

const {
  title, seoTitle, description, dek, byline,
  published, updated, hero, heroAlt, ogImage, readingTime,
} = Astro.props;

const pageTitle = seoTitle ?? `${title} | ${SITE.name}`;
const canonical = new URL(Astro.url.pathname.replace(/\.html$/, '').replace(/\/+$/, '') || '/', Astro.site).href;
const ogSrc = ogImage ?? hero;
const ogAbs = ogSrc ? new URL(ogSrc.src, Astro.site).href : undefined;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  ...(ogAbs ? { image: ogAbs } : {}),
  datePublished: published.toISOString(),
  dateModified: (updated ?? published).toISOString(),
  author: { '@type': 'Person', name: 'Dan Seals' },
  publisher: { '@type': 'Organization', name: SITE.name, url: new URL('/', Astro.site).href },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};
---
<Layout title={pageTitle} description={description} ogImage={ogAbs}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <article class="post-page">
    <header class="post-head">
      <p class="kicker"><a href="/blog">From the workbench</a></p>
      <h1 class="display post-head__title">{title}</h1>
      <p class="post-head__dek">{dek}</p>
      <p class="post-head__meta">
        {byline} · <time datetime={published.toISOString()}>{fmt(published)}</time>
        {updated && <span> · Updated {fmt(updated)}</span>}
        <span> · {readingTime} min read</span>
      </p>
    </header>

    {hero && (
      <figure class="post-hero">
        <Image
          src={hero}
          alt={heroAlt ?? ''}
          widths={[480, 720, 960, 1320]}
          sizes="(min-width: 760px) 680px, 100vw"
          loading="eager"
          class="post-hero__img"
        />
      </figure>
    )}

    <div class="post-body guide-prose">
      <slot />
    </div>

    <div class="post-cta-wrap">
      <GuideCTA />
    </div>
  </article>

  <script>
    // Same anonymous read-depth signal the guides use, namespaced per post.
    import { track } from '@/lib/telemetry';
    const post = location.pathname.match(/\/blog\/([^/]+)/)?.[1] || 'blog';
    const hit = new Set<number>();
    function checkDepth() {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      if (scrollable <= 0) return;
      const pct = Math.min(100, Math.round((window.scrollY / scrollable) * 100));
      for (const m of [25, 50, 75, 100]) {
        if (pct >= m && !hit.has(m)) { hit.add(m); track('Post.Read', { post, depth: String(m) }); }
      }
    }
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) { ticking = true; requestAnimationFrame(() => { checkDepth(); ticking = false; }); }
    }, { passive: true });
    checkDepth();
  </script>
</Layout>

<style>
  .post-page { background: var(--off-white); }
  .post-head {
    max-width: 44rem; margin-inline: auto;
    padding: clamp(2.5rem, 7vw, 4.5rem) var(--gutter) 0;
  }
  .post-head .kicker a { color: var(--green-primary); text-decoration: none; }
  .post-head .kicker a:hover { text-decoration: underline; }
  .post-head__title {
    font-size: clamp(1.9rem, 5.5vw, 2.9rem); line-height: 1.12;
    color: var(--ink); margin: 0.5rem 0 0;
  }
  .post-head__dek { color: var(--muted); font-size: var(--fs-lead); line-height: 1.55; margin: 1rem 0 0; }
  .post-head__meta { color: var(--muted); font-size: 0.9rem; margin: 1.1rem 0 0; }

  .post-hero {
    max-width: 44rem; margin: clamp(1.6rem, 4vw, 2.4rem) auto 0;
    padding: 0 var(--gutter);
  }
  .post-hero__img {
    width: 100%; height: auto; display: block;
    border-radius: var(--radius); border: 1px solid rgba(45, 106, 79, 0.12);
  }

  .post-body {
    max-width: 44rem; margin-inline: auto;
    padding: clamp(1.6rem, 4vw, 2.4rem) var(--gutter) 0;
  }
  .post-cta-wrap {
    max-width: var(--maxw); margin-inline: auto;
    padding: clamp(2rem, 5vw, 3rem) var(--gutter) clamp(3rem, 7vw, 5rem);
  }
</style>
