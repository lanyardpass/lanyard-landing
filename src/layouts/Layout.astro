---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  /** WIP branch deploys are auto-noindexed by Netlify; this is an extra belt. */
  noindex?: boolean;
  /** Absolute URL to override the sitewide social card (e.g. a guide's hero). */
  ogImage?: string;
}

const {
  title = `${SITE.name} — Watch your pass pay for itself`,
  description = SITE.description,
  ogImage: ogImageOverride,
  // Non-production build contexts set PUBLIC_NOINDEX=true (see netlify.toml).
  // The most-recent branch deploy is otherwise indexable by default, so this
  // keeps WIP out of search engines while production stays indexable.
  noindex = import.meta.env.PUBLIC_NOINDEX === 'true',
} = Astro.props;

// Single link-preview card sitewide for the beta phase (matches beta.html).
// Swap back to /og-image.png at App Store launch. A page can override it (a
// guide passes its hero) via the `ogImage` prop.
const ogImage = ogImageOverride ?? new URL('/og-image-beta.png?v=1', Astro.site).href;

// Canonical URL for this page — strips query strings (e.g. ?src=reddit) so
// channel-tagged inbound links consolidate to one URL instead of splitting
// ranking signals. Drives both <link rel=canonical> and og:url.
//
// Normalize the path to the slashless, extensionless canonical form: with
// `build.format: 'file'` Astro.url.pathname comes through as `/beta.html`, and a
// trailing slash can sneak in too — strip both so the canonical is always
// `/beta` (never `/beta.html` or `/beta/`). Root stays `/`.
const cleanPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/+$/, '') || '/';
const canonical = new URL(cleanPath, Astro.site).href;

// Structured data: tells search engines this site is an iOS app, not a blog.
// Category is Travel (theme-park vertical — same neighborhood as the official
// Disney/Universal apps + Touring Plans), with a free offer. NO aggregateRating
// until there are real App Store ratings — faking review markup is a Google
// penalty. Add the App Store URL + rating once the app ships.
const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'TravelApplication',
  name: SITE.name,
  applicationCategory: 'TravelApplication',
  operatingSystem: 'iOS',
  description: SITE.description,
  url: new URL('/', Astro.site).href,
  image: ogImage,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: SITE.name, url: new URL('/', Astro.site).href },
};

// TelemetryDeck "Lanyard Web" app (privacy-first, cookieless, no IP storage).
// Reuses the existing web app — same property, just redesigned. Flag signals
// as TEST on non-production builds (branch/preview, where PUBLIC_NOINDEX is set)
// so WIP traffic stays out of the live numbers. Localhost is auto-flagged by
// the SDK. The appID is public by design (it ships in the client).
const TD_APP_ID = '155A1765-42BE-4F22-B380-691BB80566D5';
const tdTestMode = import.meta.env.PUBLIC_NOINDEX === 'true';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lanyard — watch your pass pay for itself" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {/* Privacy-first web analytics. Fires one pageView per load; ?src=… rides
        in the URL for channel attribution. Excluded from /admin (own layout). */}
    <script
      is:inline
      src="https://cdn.telemetrydeck.com/websdk/telemetrydeck.min.js"
      data-app-id={TD_APP_ID}
      data-is-test-mode={tdTestMode ? 'true' : undefined}
    ></script>

    {/* Per-page <head> extras (e.g. a guide's Article + FAQPage JSON-LD). */}
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
