---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  /** WIP branch deploys are auto-noindexed by Netlify; this is an extra belt. */
  noindex?: boolean;
}

const {
  title = `${SITE.name} — Watch your pass pay for itself`,
  description = SITE.description,
  // Non-production build contexts set PUBLIC_NOINDEX=true (see netlify.toml).
  // The most-recent branch deploy is otherwise indexable by default, so this
  // keeps WIP out of search engines while production stays indexable.
  noindex = import.meta.env.PUBLIC_NOINDEX === 'true',
} = Astro.props;

const ogImage = new URL('/og-image.png', Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
