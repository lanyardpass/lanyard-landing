---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  /** WIP branch deploys are auto-noindexed by Netlify; this is an extra belt. */
  noindex?: boolean;
}

const {
  title = `${SITE.name} — Watch your pass pay for itself`,
  description = SITE.description,
  // Non-production build contexts set PUBLIC_NOINDEX=true (see netlify.toml).
  // The most-recent branch deploy is otherwise indexable by default, so this
  // keeps WIP out of search engines while production stays indexable.
  noindex = import.meta.env.PUBLIC_NOINDEX === 'true',
} = Astro.props;

// Single link-preview card sitewide for the beta phase (matches beta.html).
// Swap back to /og-image.png at App Store launch.
const ogImage = new URL('/og-image-beta.png?v=1', Astro.site).href;

// TelemetryDeck "Lanyard Web" app (privacy-first, cookieless, no IP storage).
// Reuses the existing web app — same property, just redesigned. Flag signals
// as TEST on non-production builds (branch/preview, where PUBLIC_NOINDEX is set)
// so WIP traffic stays out of the live numbers. Localhost is auto-flagged by
// the SDK. The appID is public by design (it ships in the client).
const TD_APP_ID = '155A1765-42BE-4F22-B380-691BB80566D5';
const tdTestMode = import.meta.env.PUBLIC_NOINDEX === 'true';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {/* Privacy-first web analytics. Fires one pageView per load; ?src=… rides
        in the URL for channel attribution. Excluded from /admin (own layout). */}
    <script
      is:inline
      src="https://cdn.telemetrydeck.com/websdk/telemetrydeck.min.js"
      data-app-id={TD_APP_ID}
      data-is-test-mode={tdTestMode ? 'true' : undefined}
    ></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
