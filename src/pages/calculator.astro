---
import Layout from '@/layouts/Layout.astro';
import CalculatorApp from '@/components/calculator/CalculatorApp.tsx';
import WaitlistForm from '@/components/WaitlistForm.astro';

export const prerender = true;

const title = 'Annual Pass Calculator — Make Your Pass Worth It | Lanyard';
const description =
  'Is your Disney, Universal, or SeaWorld annual pass worth it? See your cost per visit, break-even, and total value recovered. The free passholder calculator from Lanyard.';

// Page-specific structured data: this is a free web tool (in addition to the
// sitewide TravelApplication app schema in Layout.astro).
const calcSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Lanyard Annual Pass Calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  url: new URL('/calculator', Astro.site).href,
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  isAccessibleForFree: true,
  publisher: { '@type': 'Organization', name: 'Lanyard', url: new URL('/', Astro.site).href },
};

// FAQ content — written in real query language; doubles as user-helpful copy and
// FAQPage structured data (eligible for rich results, matches question searches).
// Single source of truth: rendered as <dl> AND serialized to JSON-LD below.
const faqs = [
  {
    q: 'How many visits does it take to break even on an annual pass?',
    a: 'It depends on what you paid and the single-day ticket price, but for most Florida theme-park passes it lands in the low single digits, often four to seven visits. Enter your pass above to see your exact break-even visit.',
  },
  {
    q: 'Is an annual pass worth it for Florida residents?',
    a: 'Usually more so. Florida-resident pricing and payment plans lower the cost, and locals tend to visit more often, which drops cost per visit fast. The calculator includes Florida-resident pricing for Universal and Disney.',
  },
  {
    q: 'Does the calculator include parking and perk savings?',
    a: 'Yes. It factors in the parking benefit for your specific tier (free or discounted), and you can add dining and other savings. Parking alone often moves your break-even up by a visit or two.',
  },
  {
    q: 'Will Epic Universe count toward my Universal Orlando annual pass?',
    a: 'As of 2026, Epic Universe is not yet included on Universal Orlando annual passes. Passholders buy a separate discounted day ticket to visit it, so for now your pass value comes from your days at Universal Studios Florida, Islands of Adventure and Volcano Bay.',
  },
  {
    q: 'Is this the same as the Lanyard app?',
    a: 'The calculator is just a taste. It gives you a one-time estimate from numbers you type in. The Lanyard app does the whole job, automatically: it logs every visit, tracks the perks and discounts you actually use, warns you before a blockout date, shows your park hours and events, and nudges you when it is time to renew. This receipt is one screen of it, kept live all year.',
  },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(calcSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="calc-page">
    <header class="calc-hero">
      <p class="kicker calc-hero__kicker">Free passholder calculator</p>
      <h1 class="display calc-hero__title">Make your pass worth it.</h1>
      <p class="calc-hero__sub">Pick your pass, drop in your visits, and watch it pay for itself. The same math that runs inside Lanyard.</p>
    </header>

    <CalculatorApp client:load />
  </section>

  <section class="calc-seo">
    <div class="calc-seo__inner">
      <h2>How to tell if your annual pass is worth it</h2>
      <p>The honest answer is almost always "yes, <em>if you use it</em>." An annual pass pays for itself the moment the days you visit add up to more than you paid. This calculator does that math for you: it values each visit at a single-day gate ticket, adds the perks you actually use (free or discounted parking, dining savings), and gives you three numbers. The goal isn't to talk you out of a pass. It's to make sure the one you have pays off.</p>

      <h3>Cost per visit</h3>
      <p>What you paid for the pass divided by how many times you go. The more you visit, the lower it drops, and the better your pass looks next to a single-day ticket.</p>

      <h3>Break-even</h3>
      <p>The visit where your pass has officially paid for itself. Every trip after that is "free" in pass terms.</p>

      <h3>Value recovered</h3>
      <p>Everything your pass gave back: the value of your visits plus the perks you used, measured against what you paid. We call it your pass's <strong>worth</strong>.</p>

      <h2>Is a Walt Disney World annual pass worth it?</h2>
      <p>Disney World's four annual passes (Incredi-Pass, Sorcerer Pass, Pirate Pass and Pixie Dust Pass, the last three for Florida residents) come down to one thing: how many days you'll actually spend in the parks. The 2025 price increases nudged the break-even up a few visits, which is exactly why it's worth tracking rather than guessing. Pick your tier above and enter your trips to see your number.</p>

      <h2>Is a Universal Orlando annual pass worth it?</h2>
      <p>Universal's four tiers (Seasonal, Power, Preferred and Premier) step up on more than price: fewer blockout dates, better parking, and bigger merchandise and dining discounts as you climb, with Premier adding after-4pm Express Pass at the top. (Worth knowing for 2026: Epic Universe isn't yet on the annual passes, so passholders still buy a separate discounted ticket to visit it.) Pick your tier, set your parking and visits, and add any discounts you use above to see where your pass pays off.</p>

      <h2>Is a SeaWorld or Busch Gardens annual pass worth it?</h2>
      <p>The United Parks Florida passes (Bronze, Silver, Gold and Platinum) are among the best per-visit values in the state, and Platinum covers all four Florida parks (SeaWorld Orlando, Busch Gardens Tampa, Aquatica and Adventure Island) with free parking. Visit even a handful of times a year and the math tends to land in your favor fast. Check yours above.</p>

      <h2>Frequently asked questions</h2>
      <dl class="calc-faq">
        {faqs.map((f) => (
          <div class="calc-faq__item">
            <dt>{f.q}</dt>
            <dd>{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="calc-wl-band">
    <div class="calc-wl-band__inner">
      <h2 class="calc-wl-band__title">Stop doing this math by hand.</h2>
      <p class="calc-wl-band__sub">Lanyard logs your visits, perks and blockouts automatically and keeps this receipt updated all year. Join the beta, or get notified at launch.</p>
      <div class="calc-wl-band__actions">
        <a class="btn btn--primary" href="/beta">Join the beta</a>
      </div>
      <WaitlistForm />
    </div>
  </section>
</Layout>

<style is:global>
  /* Namespaced under .calc / .calc-* so these reach the React island's markup
     (Astro scoped styles can't), matching the beta.astro pattern. */

  .calc-page { background: var(--off-white); color: var(--ink); }
  .calc-hero {
    max-width: 40rem; margin-inline: auto;
    padding: clamp(2.5rem, 7vw, 4.5rem) var(--gutter) 0;
    text-align: center;
  }
  .calc-hero__kicker { color: var(--green-primary); }
  .calc-hero__title { font-size: clamp(2rem, 7vw, 3.2rem); margin-top: 0.5rem; }
  .calc-hero__sub { color: var(--muted); margin: 1rem auto 0; max-width: 30rem; font-size: var(--fs-lead); }

  .calc {
    max-width: 56rem; margin-inline: auto;
    padding: clamp(1.6rem, 5vw, 2.4rem) var(--gutter) clamp(3rem, 8vw, 5rem);
  }
  /* Selection steps + pills stay a comfortable single-column width and centered;
     only the result step opens up to two columns (see .calc-details below). */
  .calc-pills, .calc-step { max-width: 33rem; margin-inline: auto; }

  /* Progress pills */
  .calc-pills { display: flex; gap: 6px; margin-bottom: 1.4rem; }
  .calc-pill { height: 5px; flex: 1; border-radius: 5px; background: rgba(45,106,79,0.15); transition: background 0.25s ease; }
  .calc-pill.on { background: var(--green-accent); }

  /* ---------- Live pass card ---------- */
  .calc-card-wrap { margin: 0 auto 1.8rem; }
  .calc-card {
    position: relative; width: 100%; max-width: 22rem; margin-inline: auto;
    aspect-ratio: 1.65 / 1; font-family: var(--font-display);
  }
  .calc-card__shadow {
    position: absolute; inset: 0; border-radius: 12px;
    background: rgba(0,0,0,0.22); transform: translate(4px, 5px);
  }
  .calc-card__chrome { position: absolute; inset: 0; border-radius: 12px; overflow: hidden; }
  .calc-card__content {
    position: absolute; inset: 0; z-index: 2; padding: 16px;
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .calc-card__operator {
    font-size: 13px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase;
    opacity: 0.7; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .calc-card__tier {
    font-size: clamp(20px, 6vw, 26px); font-weight: 700; line-height: 1.05; margin-top: 4px;
    overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }
  .calc-card__foot { align-self: flex-end; text-align: right; }
  .calc-card__foot-label {
    font-size: 9px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; opacity: 0.5;
  }
  .calc-card__stripe {
    position: absolute; top: 12px; right: 8px; z-index: 3;
    writing-mode: vertical-rl; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; opacity: 0.9;
  }

  /* ---------- Steps ---------- */
  .calc-step { margin-top: 0.4rem; }

  /* Result step — single column on mobile, two columns on desktop:
     left = your pass + the inputs, right = the payback receipt + handoff. */
  .calc-result { margin-top: 0.4rem; }
  .calc-details { display: grid; gap: 1.6rem; }
  @media (min-width: 980px) {
    .calc-details {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 2.8rem; align-items: start;
    }
    /* Receipt stays in view while you tweak the inputs on the left. */
    .calc-details__result { position: sticky; top: 5.5rem; }
    /* Card fills its column instead of the fixed narrow preview width. */
    .calc-details__inputs .calc-card { max-width: 24rem; }
  }
  .calc-q { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.01em; margin-bottom: 1rem; }
  .calc-q--mt { margin-top: 1.6rem; }
  .calc-choices { display: grid; gap: 10px; }
  .calc-choice {
    display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
    width: 100%; text-align: left; padding: 1rem 1.1rem;
    background: #fff; border: 1.5px solid rgba(45,106,79,0.12); border-radius: 14px;
    font-size: 1rem; font-weight: 600; color: var(--ink); font-family: inherit; cursor: pointer;
    transition: border-color 0.15s, transform 0.08s, background 0.15s;
  }
  .calc-choice:hover { border-color: var(--green-accent); }
  .calc-choice:active { transform: scale(0.99); }
  .calc-choice__note { display: block; font-size: 0.8rem; font-weight: 500; color: var(--muted); margin-top: 2px; }
  .calc-arrow { color: var(--green-accent); flex-shrink: 0; }
  .calc-seg { display: flex; gap: 10px; }
  .calc-seg__btn { justify-content: center; }
  .calc-seg__btn.sel { border-color: var(--green-accent); background: rgba(82,183,136,0.12); }
  .calc-nav { display: flex; gap: 10px; margin-top: 1.4rem; align-items: center; }
  .calc-nav .calc-continue { margin-left: auto; }
  .calc-ghost {
    padding: 0.85rem 1.3rem; border-radius: var(--pill); border: 1.5px solid rgba(45,106,79,0.18);
    background: transparent; color: var(--muted); font-weight: 700; font-size: 0.9rem;
    font-family: var(--font-display); cursor: pointer;
  }
  .calc-ghost:hover { border-color: var(--green-accent); color: var(--green-primary); }
  .calc-continue {
    padding: 0.85rem 1.4rem; border-radius: var(--pill); border: 0;
    background: var(--green-accent); color: var(--green-dark); font-weight: 800; font-size: 0.95rem;
    font-family: var(--font-display); cursor: pointer;
  }

  /* ---------- Detail fields ---------- */
  .calc-fields { display: grid; gap: 1.3rem; margin-bottom: 1.8rem; }
  .calc-field label { display: block; font-size: 0.9rem; font-weight: 700; margin-bottom: 0.5rem; }
  .calc-money-input, .calc-visits {
    display: flex; align-items: center; gap: 0.4rem;
  }
  .calc-money-input {
    border: 1.5px solid rgba(45,106,79,0.15); border-radius: 12px; background: #fff;
    padding: 0 0.9rem;
  }
  .calc-money-input:focus-within { border-color: var(--green-accent); }
  .calc-money-input > span { color: var(--muted); font-weight: 600; }
  .calc-money-input input {
    flex: 1; min-width: 0; padding: 0.85rem 0.2rem; border: 0; background: transparent;
    font-size: 1.1rem; font-family: inherit; color: var(--ink); outline: none; font-weight: 600;
  }
  .calc-money-input--sm { max-width: 9rem; }
  .calc-money-input--sm input { font-size: 1rem; padding: 0.7rem 0.2rem; }
  .calc-hint { font-size: 0.82rem; color: var(--muted); margin-top: 0.45rem; }
  .calc-link {
    background: none; border: 0; padding: 0; color: var(--green-primary); font: inherit;
    font-size: 0.82rem; font-weight: 600; text-decoration: underline; cursor: pointer;
  }
  .calc-visits__num {
    width: 4.2rem; padding: 0.6rem 0.5rem; border: 1.5px solid rgba(45,106,79,0.15);
    border-radius: 10px; background: #fff; font-size: 1rem; font-weight: 700; color: var(--ink);
    text-align: center; font-family: inherit; outline: none;
  }
  .calc-visits input[type=range] { flex: 1; accent-color: var(--green-accent); }
  .calc-toggles { display: grid; gap: 1rem; }
  .calc-toggle { display: flex; align-items: center; gap: 0.6rem; font-size: 0.95rem; font-weight: 500; cursor: pointer; }
  .calc-toggle input { width: 1.1rem; height: 1.1rem; accent-color: var(--green-accent); flex-shrink: 0; }

  /* Tier parking-option picker (e.g. Premier: Regular / Prime / Valet) */
  .calc-parking__opts { display: flex; gap: 8px; margin-top: 0.7rem; }
  .calc-park-opt {
    flex: 1; display: flex; flex-direction: column; gap: 2px; align-items: flex-start;
    padding: 0.6rem 0.7rem; background: #fff; border: 1.5px solid rgba(45,106,79,0.14);
    border-radius: 12px; cursor: pointer; font-family: inherit; text-align: left;
    transition: border-color 0.15s, background 0.15s;
  }
  .calc-park-opt:hover { border-color: var(--green-accent); }
  .calc-park-opt.sel { border-color: var(--green-accent); background: rgba(82,183,136,0.12); }
  .calc-park-opt__label { font-size: 0.82rem; font-weight: 700; color: var(--ink); }
  .calc-park-opt__val { font-size: 0.78rem; font-weight: 600; color: var(--green-primary); font-variant-numeric: tabular-nums; }
  .calc-parking__none { margin-top: 0; }
  .calc-field--inline { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .calc-field--inline label { margin-bottom: 0; }

  /* ---------- Payback receipt ---------- */
  .calc-receipt {
    max-width: 25rem; margin: 0 auto; background: #FBFAF4; border-radius: 8px; overflow: hidden;
    box-shadow: 0 1px 0 rgba(0,0,0,0.04), 0 6px 16px rgba(0,0,0,0.06);
  }
  .calc-receipt__stripe { height: 6px; width: 100%; }
  .calc-receipt__body { padding: 22px; }
  .calc-receipt__header {
    font-size: 11px; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase;
    color: rgba(20,53,42,0.6); line-height: 1.4;
  }
  .calc-receipt__sub {
    font-size: 11px; font-weight: 800; letter-spacing: 1.6px; color: rgba(20,53,42,0.6); margin-top: 4px;
  }
  .calc-receipt__main { display: flex; align-items: center; gap: 22px; margin-top: 18px; }
  .calc-ring { flex-shrink: 0; }
  .calc-ring__arc { transition: stroke-dashoffset 1.05s cubic-bezier(0.22, 1, 0.36, 1); }
  .calc-receipt__stats { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; min-height: 116px; }
  .calc-stat__row { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
  .calc-stat__label { font-size: 11px; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; color: rgba(20,53,42,0.6); }
  .calc-stat__value {
    font-size: 14px; font-weight: 700; color: var(--ink);
    font-variant-numeric: tabular-nums; white-space: nowrap;
  }
  .calc-stat--big .calc-stat__value { font-size: 28px; font-weight: 800; }
  .calc-stat__rule { height: 1px; background: rgba(0,0,0,0.16); margin-top: 4px; }

  /* ---------- Coach + CTA ---------- */
  .calc-coach { text-align: center; margin-top: 1.8rem; }
  .calc-coach__title { font-family: var(--font-display); font-weight: 800; font-size: 1.2rem; color: var(--green-primary); }
  .calc-coach__body { color: var(--muted); max-width: 26rem; margin: 0.4rem auto 0; }

  .calc-cta { text-align: center; margin-top: 2.2rem; padding-top: 1.8rem; border-top: 1px solid rgba(45,106,79,0.12); }
  .calc-cta__lead { color: var(--ink); font-weight: 600; max-width: 24rem; margin: 0 auto 1rem; }
  .calc-cta__btn {
    display: inline-block; padding: 0.95rem 1.8rem; border-radius: var(--pill);
    background: var(--green-accent); color: var(--green-dark); font-family: var(--font-display);
    font-weight: 800; font-size: 1.02rem; text-decoration: none;
  }
  .calc-cta__edit { display: block; margin: 1.1rem auto 0; }

  /* ---------- SEO content (static prose Google can read + users who scroll) ---------- */
  .calc-seo { background: var(--off-white); color: var(--ink); }
  .calc-seo__inner {
    max-width: 42rem; margin-inline: auto;
    padding: clamp(1rem, 4vw, 2rem) var(--gutter) clamp(3rem, 8vw, 5rem);
  }
  .calc-seo h2 {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(1.3rem, 4vw, 1.7rem); color: var(--green-primary);
    margin: 2.4rem 0 0.7rem; line-height: 1.15;
  }
  .calc-seo h2:first-child { margin-top: 0; }
  .calc-seo h3 {
    font-family: var(--font-display); font-weight: 800; font-size: 1.05rem;
    color: var(--ink); margin: 1.4rem 0 0.3rem;
  }
  .calc-seo p { color: var(--muted); line-height: 1.7; margin: 0 0 0.9rem; }
  .calc-seo strong { color: var(--ink); }

  .calc-faq { margin: 0.6rem 0 0; }
  .calc-faq__item { padding: 1.1rem 0; border-top: 1px solid rgba(45,106,79,0.12); }
  .calc-faq dt { font-family: var(--font-display); font-weight: 700; color: var(--ink); margin-bottom: 0.4rem; }
  .calc-faq dd { margin: 0; color: var(--muted); line-height: 1.7; }

  /* ---------- Waitlist band (dark, so WaitlistForm renders as designed) ---------- */
  .calc-wl-band { background: var(--dark-gradient); color: var(--on-dark); }
  .calc-wl-band__inner {
    max-width: 40rem; margin-inline: auto; text-align: center;
    padding: clamp(3rem, 8vw, 5rem) var(--gutter);
  }
  .calc-wl-band__title { font-family: var(--font-display); font-weight: 800; font-size: var(--fs-h2); }
  .calc-wl-band__sub { color: var(--on-dark-muted); margin: 0.9rem auto 1.6rem; max-width: 30rem; }
  .calc-wl-band__actions { margin-bottom: 1.6rem; }

  @media (prefers-reduced-motion: reduce) {
    .calc-ring__arc { transition: none; }
    .calc-choice { transition: none; }
  }
</style>
