---
// A below-the-fold feature row: text on one side, a flat-framed phone on the
// other. Reusable — content is props. `side` flips which side the phone sits.
import DeviceFrame from '@/components/DeviceFrame.astro';
interface Props {
  id?: string;
  kicker: string;
  headline: string;
  body: string;
  screen: string;
  screenAlt: string;
  side?: 'left' | 'right';
  dark?: boolean;
}
const { id, kicker, headline, body, screen, screenAlt, side = 'right', dark = false } = Astro.props;
---
<section id={id} class={`section spotlight${dark ? ' section--dark' : ''} spotlight--phone-${side}`}>
  <div class="container spotlight__inner">
    <div class="spotlight__text">
      <p class="kicker">{kicker}</p>
      <h2 class="display spotlight__title">{headline}</h2>
      <p class="spotlight__body">{body}</p>
    </div>
    <div class="spotlight__device">
      <DeviceFrame src={screen} alt={screenAlt} />
    </div>
  </div>
</section>

<style>
  .spotlight__inner {
    display: grid;
    grid-template-columns: 1fr minmax(0, 0.6fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }
  /* Phone-left variant: swap the DOM order via grid order. */
  .spotlight--phone-left .spotlight__text { order: 2; }
  .spotlight--phone-left .spotlight__device { order: 1; }
  .spotlight__title { font-size: var(--fs-h2); margin-top: 0.6rem; max-width: 16ch; }
  .spotlight__body {
    font-size: var(--fs-lead);
    line-height: 1.5;
    margin-top: 1.1rem;
    max-width: 42ch;
    color: var(--muted);
  }
  .section--dark .spotlight__body { color: var(--on-dark-muted); }
  .spotlight__device { justify-self: center; width: min(290px, 78%); }
  @media (max-width: 760px) {
    .spotlight__inner { grid-template-columns: 1fr; gap: clamp(1.5rem, 6vw, 2.5rem); text-align: center; }
    .spotlight--phone-left .spotlight__text,
    .spotlight--phone-left .spotlight__device { order: initial; }
    .spotlight__title, .spotlight__body { margin-inline: auto; }
    .spotlight__device { width: min(235px, 60%); order: 2; }
    .spotlight__text { order: 1; }
  }
</style>
