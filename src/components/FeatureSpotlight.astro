---
// A below-the-fold feature row: text on one side, a flat-framed phone on the
// other. Reusable — content is props. `side` flips which side the phone sits.
import DeviceFrame from '@/components/DeviceFrame.astro';
interface Props {
  id?: string;
  kicker: string;
  headline: string;
  body: string;
  screen: string;
  screenAlt: string;
  side?: 'left' | 'right';
  dark?: boolean;
  /** Render the kicker as a solid accent pill — the new-feature announcement slot. */
  pill?: boolean;
  /** Optional ghost-button link under the body (e.g. a deep-dive page). */
  cta?: { label: string; href: string };
}
const { id, kicker, headline, body, screen, screenAlt, side = 'right', dark = false, pill = false, cta } = Astro.props;
// Lean the phone toward the copy (opposite the side it sits on).
const lean = side === 'left' ? 'right' : 'left';
---
<section id={id} class={`section spotlight${dark ? ' section--dark' : ''} spotlight--phone-${side}`}>
  <div class="container spotlight__inner">
    <div class="spotlight__text">
      <p class={pill ? 'kicker kicker--pill' : 'kicker'}>{kicker}</p>
      <h2 class="display spotlight__title">{headline}</h2>
      <p class="spotlight__body">{body}</p>
      {cta && <a class="btn btn--ghost spotlight__cta" href={cta.href}>{cta.label}</a>}
    </div>
    <div class="spotlight__device">
      <DeviceFrame src={screen} alt={screenAlt} lean={lean} />
    </div>
  </div>
</section>

<style>
  .spotlight__inner {
    display: grid;
    grid-template-columns: 1fr minmax(0, 0.6fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }
  /* Phone-left variant: swap the DOM order via grid order. */
  .spotlight--phone-left .spotlight__text { order: 2; }
  .spotlight--phone-left .spotlight__device { order: 1; }
  .spotlight__title { font-size: var(--fs-h2); margin-top: 0.6rem; max-width: 16ch; }
  .spotlight__body {
    font-size: var(--fs-lead);
    line-height: 1.5;
    margin-top: 1.1rem;
    max-width: 42ch;
    color: var(--muted);
  }
  .section--dark .spotlight__body { color: var(--on-dark-muted); }
  .spotlight__device { justify-self: center; width: min(290px, 78%); }
  /* New-feature pill kicker — solid accent so it reads at a scroll-by glance;
     tighter tracking than the bare kicker (pill supplies the emphasis). */
  .kicker--pill {
    display: inline-block;
    background: var(--green-accent);
    color: var(--ink);
    padding: 0.32rem 0.8rem;
    border-radius: var(--pill);
    letter-spacing: 0.12em;
  }
  .section--dark .kicker--pill { color: var(--ink); }
  .spotlight__cta { margin-top: 1.5rem; }
  @media (max-width: 760px) {
    .spotlight__inner { grid-template-columns: 1fr; gap: clamp(1.5rem, 6vw, 2.5rem); text-align: center; }
    .spotlight--phone-left .spotlight__text,
    .spotlight--phone-left .spotlight__device { order: initial; }
    .spotlight__title, .spotlight__body { margin-inline: auto; }
    .spotlight__device { width: min(235px, 60%); order: 2; }
    .spotlight__text { order: 1; }
  }
</style>
