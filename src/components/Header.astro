---
import { NAV, CTA } from '@/data/site';
import LanyardLogo from '@/components/LanyardLogo.astro';
---
<header class="site-header">
  <div class="site-header__inner container">
    <a class="wordmark" href="/" aria-label="Lanyard home">
      <LanyardLogo width={150} label="" />
    </a>
    <nav class="site-nav" aria-label="Primary">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="site-header__actions">
      <a class="btn btn--primary site-header__cta" href={CTA.href}>{CTA.label}</a>
    </div>
    <button class="site-header__burger" id="burgerBtn" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>

  {/* Mobile dropdown — the nav lives here on phones (it's hidden from the bar
      below 720px), so the Calculator and other pages are actually findable. */}
  <div class="site-mobile-menu" id="mobileMenu" hidden>
    <nav class="site-mobile-menu__nav" aria-label="Mobile">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="site-mobile-menu__ctas">
      <a class="btn btn--primary" href={CTA.href}>{CTA.label}</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('burgerBtn');
  const menu = document.getElementById('mobileMenu');
  if (btn && menu) {
    const setOpen = (open: boolean) => {
      if (open) menu.removeAttribute('hidden');
      else menu.setAttribute('hidden', '');
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      btn.classList.toggle('open', open);
    };
    btn.addEventListener('click', () => setOpen(menu.hasAttribute('hidden')));
    // Close after navigating, on Escape, or when tapping outside the menu.
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hasAttribute('hidden')) { setOpen(false); btn.focus(); }
    });
    document.addEventListener('click', (e) => {
      const t = e.target as Node;
      if (!menu.hasAttribute('hidden') && !menu.contains(t) && !btn.contains(t)) setOpen(false);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--green-dark) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 64px;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    text-decoration: none;
  }
  .site-nav {
    display: flex;
    gap: 1.6rem;
    margin-left: auto;
    margin-right: 0.5rem;
  }
  .site-nav a {
    color: var(--on-dark-muted);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    transition: color 0.15s ease;
  }
  .site-nav a:hover { color: var(--on-dark); }

  .site-header__actions { display: flex; align-items: center; gap: 0.6rem; }
  .site-header__cta { padding: 0.55rem 1.2rem; font-size: 0.92rem; white-space: nowrap; }

  /* ---- Hamburger (mobile only) ---- */
  .site-header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 9px;
    background: transparent;
    border: 0;
    cursor: pointer;
    border-radius: 8px;
  }
  .site-header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: var(--on-dark);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .site-header__burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .site-header__burger.open span:nth-child(2) { opacity: 0; }
  .site-header__burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ---- Mobile dropdown panel ---- */
  .site-mobile-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--green-dark);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.35);
    padding: 0.4rem var(--gutter) 1.3rem;
  }
  .site-mobile-menu__nav { display: flex; flex-direction: column; }
  .site-mobile-menu__nav a {
    color: var(--on-dark);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.95rem 0.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .site-mobile-menu__nav a:active { color: var(--green-accent); }
  .site-mobile-menu__ctas { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1.1rem; }
  .site-mobile-menu__ctas > a {
    display: block;
    width: 100%;
    text-align: center;
    box-sizing: border-box;
  }

  /* Switch to the hamburger at ≤1024px. The inline nav (4 links + two full CTA
     buttons + logo) only fits on one line above ~1024; below that it wraps ugly
     ("What / it / does"), so every tablet-in-portrait — incl. the 12.9" iPad at
     1024 — gets the clean menu instead. Verified empirically at 834/900/1024.
     The CTA does NOT hide with the nav (changed 2026-07-09): the primary
     conversion action stays visible in the sticky bar on every width — the
     burger only holds navigation. Logo + compact pill + burger fit to 375px;
     ≤380px tightens the pill for the SE/mini. The dropdown keeps its own CTA
     copy for menu-open state. */
  @media (max-width: 1024px) {
    .site-nav { display: none; }
    .site-header__inner { gap: 0.75rem; }
    .site-header__actions { margin-left: auto; }
    .site-header__cta { padding: 0.5rem 1rem; font-size: 0.9rem; }
    .site-header__burger { display: inline-flex; }
    .site-mobile-menu:not([hidden]) { display: block; }
  }
  @media (max-width: 380px) {
    .site-header__cta { padding: 0.45rem 0.85rem; font-size: 0.86rem; }
  }
</style>
