---
// The plaza demo on /crowds — a hand-driven miniature of the app's crowd
// scene. Three word-buttons (Quiet / Normal / Packed — the app's DISPLAY
// words; internal id "steady" never appears on user surfaces) drive a
// silhouette diorama: figures fill in as the word climbs, the balloon shows
// up at Packed (with the app's documented 20% escape roll, rolled once per
// page load), and a steam train rarely crosses the back at Packed — the
// same train LAN-187 brings to the app's USF/IoA scenes.
//
// FIGURE ART IS THE REAL CAST: unit-square SVGs generated from the app's
// CrowdFigures.swift by tools/dump-shape-svgs.py (lanyard-docs →
// brand/crowd-figures/, copied into src/assets/parkfolk/ — README there).
// Width/height per figure come from the app registry's relHeight/aspect, so
// the plaza's proportions match the card's. Re-copy after figure changes.
//
// Honesty contract: this demo NEVER shows a real crowd reading. The caption
// says so; the finger drives it here, the evidence drives it in the app.
import coupleRaw from '@/assets/parkfolk/CrowdFigureCoupleShape.svg?raw';
import relaxedRaw from '@/assets/parkfolk/CrowdFigureRelaxedShape.svg?raw';
import phoneRaw from '@/assets/parkfolk/CrowdFigurePhoneShape.svg?raw';
import crossedRaw from '@/assets/parkfolk/CrowdFigureCrossedShape.svg?raw';
import hipsRaw from '@/assets/parkfolk/CrowdFigureHipsShape.svg?raw';
import walkARaw from '@/assets/parkfolk/CrowdFigureWalkAShape.svg?raw';
import strollerRaw from '@/assets/parkfolk/CrowdFigureStrollerAShape.svg?raw';
import shouldersRaw from '@/assets/parkfolk/CrowdFigureShouldersShape.svg?raw';
import skipGirlRaw from '@/assets/parkfolk/CrowdFigureSkipGirlAShape.svg?raw';
import ecvRaw from '@/assets/parkfolk/CrowdFigureEcvShape.svg?raw';

// Base figure unit in px (front row). relHeight values mirror the app
// registry (CrowdFigures.swift named figures / frames). The dumped SVGs
// carry TRUE proportions inside the unit square (figure centered, dominant
// axis filling 0→1 — see brand/crowd-figures/README.md), so each renders
// in a SQUARE box of its height. Do NOT stretch by aspect — that double-
// applies it and squishes the figures (earned 2026-07-16).
const U = 72;
const art = (raw: string, relHeight: number) => {
  const h = (relHeight * U).toFixed(1);
  return raw
    .replace('<svg ', `<svg width="${h}" height="${h}" `)
    .replace('fill="black"', 'fill="currentColor"');
};
const ART: Record<string, string> = {
  couple: art(coupleRaw, 0.84),
  relaxed: art(relaxedRaw, 0.8),
  phone: art(phoneRaw, 0.78),
  crossed: art(crossedRaw, 0.8),
  hips: art(hipsRaw, 0.8),
  walker: art(walkARaw, 0.76),
  stroller: art(strollerRaw, 0.87),
  shoulders: art(shouldersRaw, 1.0),
  skipKid: art(skipGirlRaw, 0.58),
  ecv: art(ecvRaw, 0.72),
  kid: art(walkARaw, 0.55),
};

// The cast. tier: 1 = present from Quiet, 2 = joins at Normal, 3 = Packed.
// back row renders smaller + lighter for depth. balloonKid wears ART.kid
// plus the code-drawn balloon (code-drawn in the app too).
const cast = [
  { kind: 'couple', tier: 1, left: 44, row: 'front', delay: 0 },
  { kind: 'walker', tier: 2, left: 14, row: 'front', delay: 0.08 },
  { kind: 'stroller', tier: 2, left: 58, row: 'front', delay: 0.16 },
  { kind: 'shoulders', tier: 2, left: 29, row: 'front', delay: 0.24 },
  { kind: 'ecv', tier: 2, left: 76, row: 'front', delay: 0.32 },
  { kind: 'relaxed', tier: 2, left: 8, row: 'back', delay: 0.1 },
  { kind: 'phone', tier: 2, left: 82, row: 'back', delay: 0.2 },
  { kind: 'crossed', tier: 3, left: 4, row: 'front', delay: 0.05 },
  { kind: 'skipKid', tier: 3, left: 22, row: 'front', delay: 0.3 },
  { kind: 'hips', tier: 3, left: 50, row: 'front', delay: 0.12 },
  { kind: 'couple', tier: 3, left: 88, row: 'front', delay: 0.2 },
  { kind: 'walker', tier: 3, left: 38, row: 'back', delay: 0.15 },
  { kind: 'couple', tier: 3, left: 52, row: 'back', delay: 0.25 },
  { kind: 'stroller', tier: 3, left: 18, row: 'back', delay: 0.35 },
  { kind: 'crossed', tier: 3, left: 66, row: 'back', delay: 0.4 },
  { kind: 'balloonKid', tier: 3, left: 68, row: 'front', delay: 0.45 },
];

const TRAIN =
  '<rect x="10" y="28" width="66" height="22" rx="4"/>' +
  '<rect x="20" y="14" width="10" height="16" rx="2"/>' +
  '<rect x="62" y="12" width="24" height="38" rx="3"/>' +
  '<circle cx="26" cy="56" r="7"/><circle cx="46" cy="56" r="7"/><circle cx="66" cy="56" r="7"/><circle cx="84" cy="56" r="7"/>' +
  '<rect x="92" y="30" width="36" height="22" rx="3"/>' +
  '<circle cx="101" cy="56" r="6"/><circle cx="119" cy="56" r="6"/>' +
  '<rect x="134" y="24" width="76" height="28" rx="5"/>' +
  '<circle cx="148" cy="56" r="6"/><circle cx="196" cy="56" r="6"/>' +
  '<rect x="216" y="24" width="76" height="28" rx="5"/>' +
  '<circle cx="230" cy="56" r="6"/><circle cx="278" cy="56" r="6"/>';
---
<div class="plaza-wrap">
  <div class="plaza__words" role="group" aria-label="Set the demo crowd level">
    <button class="plaza__btn" data-set="quiet" aria-pressed="true">Quiet</button>
    <button class="plaza__btn" data-set="normal" aria-pressed="false">Normal</button>
    <button class="plaza__btn" data-set="packed" aria-pressed="false">Packed</button>
  </div>

  <div class="plaza" id="crowd-plaza" data-state="quiet" aria-hidden="true">
    <div class="plaza__train" id="plaza-train">
      <svg viewBox="0 0 300 64" width="300" height="64" set:html={TRAIN} />
    </div>
    {cast.map((f) => (
      <span
        class={`plaza__fig plaza__fig--t${f.tier} plaza__fig--${f.row}`}
        style={`left:${f.left}%;transition-delay:${f.delay}s;--s:${f.row === 'back' ? 0.8 : 1}`}
      >
        {f.kind === 'balloonKid' && (
          <span class="plaza__balloon" id="plaza-balloon">
            <svg viewBox="0 0 20 46" width="15" height="34">
              <circle cx="10" cy="9" r="8" />
              <path d="M10 17 q4 12 -1 28" fill="none" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </span>
        )}
        <span set:html={ART[f.kind === 'balloonKid' ? 'kid' : f.kind]} />
      </span>
    ))}
    <div class="plaza__ground"></div>
  </div>

  <p class="plaza__readout"><b id="plaza-word">QUIET</b> <span id="plaza-sentence">Short waits. Room to breathe.</span></p>
  <p class="plaza__truth">
    Here, your finger sets the crowd. In the app, more than ten thousand park-days of evidence do.
  </p>
</div>

<script is:inline>
  (function () {
    var plaza = document.getElementById('crowd-plaza');
    var wordEl = document.getElementById('plaza-word');
    var sentEl = document.getElementById('plaza-sentence');
    var train = document.getElementById('plaza-train');
    var balloon = document.getElementById('plaza-balloon');
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var STATES = {
      quiet: { word: 'QUIET', s: 'Short waits. Room to breathe.' },
      normal: { word: 'NORMAL', s: 'A typical day for this park.' },
      packed: { word: 'PACKED', s: "Waits are running well above this park's normal." },
    };

    // The balloon's fate is rolled ONCE, like the app's escape chance.
    var balloonEscapes = Math.random() < 0.2;
    var balloonDone = false;
    var trainTimer = null;

    function crossTrain() {
      if (reduce) return;
      train.classList.remove('plaza__train--run');
      void train.offsetWidth;
      train.classList.add('plaza__train--run');
    }

    function setState(s) {
      plaza.setAttribute('data-state', s);
      wordEl.textContent = STATES[s].word;
      sentEl.textContent = STATES[s].s;
      document.querySelectorAll('.plaza__btn').forEach(function (b) {
        b.setAttribute('aria-pressed', String(b.getAttribute('data-set') === s));
      });
      clearTimeout(trainTimer);
      if (s === 'packed') {
        trainTimer = setTimeout(function tick() {
          crossTrain();
          trainTimer = setTimeout(tick, 26000 + Math.random() * 18000);
        }, 2500);
        if (balloonEscapes && !balloonDone && !reduce) {
          setTimeout(function () {
            if (plaza.getAttribute('data-state') === 'packed' && !balloonDone) {
              balloonDone = true;
              balloon.classList.add('plaza__balloon--fly');
            }
          }, 5000 + Math.random() * 4000);
        }
      }
    }

    document.querySelectorAll('.plaza__btn').forEach(function (b) {
      b.addEventListener('click', function () { setState(b.getAttribute('data-set')); });
    });
  })();
</script>

<style is:global>
  .plaza-wrap { margin-top: 1.1rem; }
  .plaza__words { display: flex; gap: 6px; }
  .plaza__btn {
    flex: 1; padding: 0.5rem 0; border-radius: 999px;
    border: 1px solid rgba(45, 106, 79, 0.3); background: #fff;
    font-family: var(--font-display); font-weight: 700; font-size: 0.85rem;
    letter-spacing: 0.04em; color: var(--green-primary); cursor: pointer;
  }
  .plaza__btn[aria-pressed='true'] { background: var(--green-primary); color: #fff; border-color: var(--green-primary); }

  .plaza {
    position: relative; height: 200px; margin-top: 0.9rem;
    border: 1px solid rgba(45, 106, 79, 0.14); border-radius: var(--radius-sm);
    background: rgba(45, 106, 79, 0.04); overflow: hidden;
  }
  .plaza__ground {
    position: absolute; left: 0; right: 0; bottom: 22px;
    border-bottom: 2px solid rgba(27, 67, 50, 0.25);
  }
  .plaza__fig {
    position: absolute; bottom: 24px; color: #1b4332;
    transform: translateY(8px) scale(var(--s, 1));
    transform-origin: bottom center;
    opacity: 0; transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .plaza__fig--back { bottom: 78px; color: #4a6e5c; z-index: 1; }
  .plaza__fig--front { z-index: 3; }
  .plaza[data-state='quiet'] .plaza__fig--t1,
  .plaza[data-state='normal'] .plaza__fig--t1,
  .plaza[data-state='normal'] .plaza__fig--t2,
  .plaza[data-state='packed'] .plaza__fig--t1,
  .plaza[data-state='packed'] .plaza__fig--t2,
  .plaza[data-state='packed'] .plaza__fig--t3 {
    opacity: 1; transform: translateY(0) scale(var(--s, 1));
  }

  .plaza__balloon {
    position: absolute; top: -30px; right: 2px; color: #c65f34;
    transition: transform 6s ease-in, opacity 6s ease-in;
  }
  .plaza__balloon--fly { transform: translateY(-190px) translateX(24px); opacity: 0; }

  .plaza__train {
    position: absolute; bottom: 96px; left: 0; color: #56705f; opacity: 0.55;
    transform: translateX(-320px); z-index: 0; pointer-events: none;
  }
  .plaza__train--run { animation: plaza-train-cross 13s linear 1; }
  @keyframes plaza-train-cross {
    from { transform: translateX(-320px); }
    to { transform: translateX(calc(100vw + 320px)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .plaza__train--run { animation: none; }
    .plaza__fig { transition: none; }
    .plaza__balloon { transition: none; }
  }

  .plaza__readout { margin: 0.9rem 0 0 !important; font-size: 0.95rem; }
  .plaza__readout b {
    font-family: var(--font-display); font-weight: 800; letter-spacing: 0.08em;
    color: var(--green-primary); margin-right: 8px;
  }
  .plaza__readout span { color: var(--muted); }
  .plaza__truth {
    margin: 0.7rem 0 0 !important; font-size: 0.85rem !important;
    color: var(--muted) !important; font-style: italic;
  }
</style>
