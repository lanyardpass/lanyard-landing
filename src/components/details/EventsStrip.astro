---
// The "next ninety days" strip on /details/calendar — a build-time render of
// the real events corpus (src/data/events_snapshot.json, written by
// scripts/snapshot-events.py) with a client-side scrubber modeled on the
// app's events calendar. The BARS are as fresh as the snapshot (the honest
// label is "as curated on <snapshot_date>"); the PLAYHEAD is live — it lands
// on the reader's actual date, clamps to the window edge when the snapshot
// has aged past it, and the day readout below lists what's on under it.
// Re-snapshot + rebuild whenever events.json changes (events runbook cadence).
import snapshot from '@/data/events_snapshot.json';

const start = new Date(snapshot.snapshot_date + 'T00:00:00');
const days = snapshot.window_days;
const MS = 86400000;
const pct = (iso: string, endInclusive = false) => {
  const d = (new Date(iso + 'T00:00:00').getTime() - start.getTime()) / MS + (endInclusive ? 1 : 0);
  return Math.min(100, Math.max(0, (d / days) * 100));
};
const fmt = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
const snapshotLabel = new Date(snapshot.snapshot_date + 'T00:00:00').toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});

// Month gridlines at each 1st-of-month inside the window.
const ticks: { label: string; left: number }[] = [];
const cursor = new Date(start.getTime());
cursor.setDate(1);
cursor.setMonth(cursor.getMonth() + 1);
while ((cursor.getTime() - start.getTime()) / MS < days) {
  ticks.push({
    label: cursor.toLocaleDateString('en-US', { month: 'short' }) + ' 1',
    left: ((cursor.getTime() - start.getTime()) / MS / days) * 100,
  });
  cursor.setMonth(cursor.getMonth() + 1);
}

// Event colors match the app's locked event palette EXACTLY (Color+Brand.swift
// → "Locked palette for the events/calendar surface", + Event.textColorOnFill:
// celebration reads dark-on-marigold, every other type reads white-on-fill).
// The strip teaches the app's color language — scanner green means "yours",
// electric blue means "separate ticket" — so update in step if that palette
// ever changes.
const LEGEND: Record<string, string> = {
  celebration: 'celebrations',
  festival: 'festivals',
  food_festival: 'food festivals',
  spectacular: 'spectaculars',
  concert_series: 'concert series',
  passholder_event: 'passholder only',
  hard_ticket_event: 'ticketed events',
  ride_event: 'ride events',
  race_weekend: 'race weekends',
  closure: 'closures',
};

type Ev = (typeof snapshot.events)[number];
const dupShorts = new Set(
  snapshot.events.map((e) => e.short).filter((s, _, all) => all.filter((x) => x === s).length > 1)
);
const label = (e: Ev) => (dupShorts.has(e.short) && e.parks.length ? `${e.short} · ${e.parks[0]}` : e.short);

// Greedy lane packing per operator, in a fixed presentation order.
const groups = Object.entries(snapshot.operators).map(([opId, opName]) => {
  const evs = snapshot.events
    .filter((e) => e.operator === opId)
    .sort((a, b) => a.from.localeCompare(b.from) || a.to.localeCompare(b.to));
  const laneEnds: number[] = [];
  const placed = evs.map((e) => {
    const left = pct(e.from);
    const right = pct(e.to, true);
    let lane = laneEnds.findIndex((end) => end + 1.5 <= left);
    if (lane === -1) { lane = laneEnds.length; laneEnds.push(right); }
    else laneEnds[lane] = right;
    const single = e.from === e.to;
    const detail =
      `${label(e)} — ${fmt(e.from)}${single ? '' : ' to ' + fmt(e.to)}` +
      (e.nights ? ` · ${e.nights} select nights` : '') +
      (e.description ? `. ${e.description}` : '');
    return { ...e, left, width: Math.max(right - left, 0.8), lane, single, family: e.type, detail };
  });
  return { opName, lanes: laneEnds.length, events: placed };
}).filter((g) => g.events.length);

const familiesPresent = [...new Set(groups.flatMap((g) => g.events.map((e) => e.family)))];

// Compact corpus for the client-side scrubber.
const clientEvents = groups.flatMap((g) =>
  g.events.map((e) => ({
    label: label(e), type: e.family, from: e.from, to: e.to,
    single: e.single, nights: e.nights, dates: e.dates, op: g.opName,
    detail: e.detail,
  }))
);
---
<section class="chapter strip">
  <p class="chapter__kicker">The proof</p>
  <h2>Every event below is real</h2>
  <p>
    This strip is drawn from the same data the app ships. It covers the ninety days ahead as
    curated on {snapshotLabel}, and it's rebuilt every time we update the site. The playhead
    lands on whatever day you're reading this. Drag it, and tap any event for the full story.
  </p>

  <div class="strip__scroll">
    <div class="strip__frame">
      <div class="strip__axis">
        <span class="strip__start">{fmt(snapshot.snapshot_date)}</span>
        {ticks.map((t) => <span class="strip__tick" style={`left:${t.left}%`}>{t.label}</span>)}
      </div>
      <div class="strip__grid">
        {ticks.map((t) => <i class="strip__line" style={`left:${t.left}%`}></i>)}
        <i class="strip__playhead" id="strip-playhead" hidden><b id="strip-playhead-label"></b></i>
        {groups.map((g) => (
          <div class="strip__group">
            <p class="strip__op">{g.opName}</p>
            <div class="strip__lanes" style={`height:${g.lanes * 24}px`}>
              {g.events.map((e) =>
                e.single ? (
                  <button
                    class={`strip__dot strip__dot--${e.family}`}
                    style={`left:${e.left}%;top:${e.lane * 24 + 3}px`}
                    data-label={label(e)}
                    aria-label={e.detail}
                  ></button>
                ) : (
                  <button
                    class={`strip__bar strip__bar--${e.family}`}
                    style={`left:${e.left}%;width:${e.width}%;top:${e.lane * 24}px`}
                    data-label={label(e)}
                    aria-label={e.detail}
                  >{e.width >= 6 && label(e)}{e.width >= 12 && e.nights > 0 && <span class="strip__nights"> · {e.nights} nights</span>}</button>
                )
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <input
    class="strip__scrub" type="range" id="strip-scrub"
    min="0" max={days} step="1" value="0"
    aria-label="Scrub through the ninety days"
  />

  <div class="strip__day" id="strip-day"></div>

  <div class="strip__legend">
    {familiesPresent.map((f) => (
      <span><i class={`strip__swatch strip__swatch--${f}`}></i> {LEGEND[f]}</span>
    ))}
  </div>
</section>

<script is:inline define:vars={{ EVENTS: clientEvents, SNAP: snapshot.snapshot_date, DAYS: days }}>
  (function () {
    var MS = 86400000;
    var start = new Date(SNAP + 'T00:00:00');
    var scrub = document.getElementById('strip-scrub');
    var head = document.getElementById('strip-playhead');
    var headLabel = document.getElementById('strip-playhead-label');
    var dayPanel = document.getElementById('strip-day');
    var openLabel = null;

    function at(v) { return new Date(start.getTime() + v * MS); }
    function isoOf(d) {
      return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
    }
    function fmtShort(d) { return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }); }
    function fmtLong(d) { return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }); }
    function esc(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;'); }

    var today = new Date(); today.setHours(0, 0, 0, 0);
    var offset = Math.round((today.getTime() - start.getTime()) / MS);
    var clamped = Math.min(Math.max(offset, 0), DAYS);
    var aged = offset > DAYS;

    function render(v) {
      var d = at(v);
      var dIso = isoOf(d);
      var isToday = v === offset;
      var p = (v / DAYS) * 100;
      head.hidden = false;
      head.style.left = p + '%';
      headLabel.textContent = isToday ? 'today' : fmtShort(d);
      headLabel.style.transform = p < 7 ? 'translateX(0)' : p > 93 ? 'translateX(-100%)' : 'translateX(-50%)';

      var scroller = document.querySelector('.strip__scroll');
      var frame = document.querySelector('.strip__frame');
      if (scroller.scrollWidth > scroller.clientWidth) {
        var x = (frame.offsetWidth * p) / 100;
        if (x < scroller.scrollLeft + 40 || x > scroller.scrollLeft + scroller.clientWidth - 40) {
          scroller.scrollLeft = x - scroller.clientWidth / 2;
        }
      }

      var rows = '';
      EVENTS.forEach(function (e) {
        if (dIso < e.from || dIso > e.to) return;
        var night = e.dates.length ? e.dates.indexOf(dIso) >= 0 : null;
        var note = e.single
          ? 'one day only'
          : night === true ? 'event night'
          : night === false ? 'no event night this date'
          : 'through ' + fmtShort(new Date(e.to + 'T00:00:00'));
        var open = openLabel === e.label;
        rows +=
          '<button class="strip__dayrow' + (night === false ? ' strip__dayrow--off' : '') + '"' +
          ' aria-expanded="' + open + '" data-label="' + esc(e.label) + '">' +
          '<i class="strip__swatch strip__swatch--' + e.type + '"></i>' +
          '<strong>' + esc(e.label) + '</strong>' +
          '<span>' + note + ' · ' + esc(e.op) + '</span>' +
          '<i class="strip__caret">' + (open ? '▾' : '▸') + '</i>' +
          (open ? '<em>' + esc(e.detail) + '</em>' : '') +
          '</button>';
      });
      if (!rows) rows = '<p class="strip__dayquiet">A quiet day. Regular hours, no events.</p>';

      var agedNote = aged && v === DAYS
        ? '<p class="strip__aged">Your today is past the end of this snapshot. The app itself is current.</p>'
        : '';
      dayPanel.innerHTML =
        '<p class="strip__dayhead">' + fmtLong(d) + (isToday ? ' · today' : '') + '</p>' + rows + agedNote;
    }

    scrub.value = clamped;
    scrub.addEventListener('input', function () { render(+scrub.value); });
    render(clamped);

    dayPanel.addEventListener('click', function (ev) {
      var row = ev.target.closest('.strip__dayrow');
      if (!row) return;
      var l = row.getAttribute('data-label');
      openLabel = openLabel === l ? null : l;
      render(+scrub.value);
    });

    document.querySelectorAll('.strip__bar, .strip__dot').forEach(function (b) {
      b.addEventListener('click', function () {
        var l = b.getAttribute('data-label');
        var e = null;
        EVENTS.forEach(function (x) { if (x.label === l) e = x; });
        if (!e) return;
        var targetIso = e.dates.length
          ? (e.dates.filter(function (x) { return x >= SNAP; })[0] || e.from)
          : e.from;
        if (targetIso < SNAP) targetIso = SNAP;
        var v = Math.round((new Date(targetIso + 'T00:00:00').getTime() - start.getTime()) / MS);
        v = Math.min(Math.max(v, 0), DAYS);
        openLabel = l;
        scrub.value = v;
        render(v);
        document.querySelectorAll('.strip--active').forEach(function (a) { a.classList.remove('strip--active'); });
        b.classList.add('strip--active');
        dayPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });
  })();
</script>

<style is:global>
  .strip__scroll { overflow-x: auto; max-width: 100%; margin-top: 1.1rem; }
  .strip__frame { min-width: 620px; padding-top: 16px; }
  .strip__axis { position: relative; height: 18px; font-size: 0.72rem; color: var(--muted); }
  .strip__start { position: absolute; left: 0; font-weight: 600; }
  .strip__tick { position: absolute; transform: translateX(-50%); }
  .strip__grid { position: relative; border-top: 1px solid rgba(45, 106, 79, 0.14); padding-top: 0.35rem; }
  .strip__line { position: absolute; top: 0; bottom: 0; width: 1px; background: rgba(45, 106, 79, 0.08); }
  .strip__playhead {
    position: absolute; top: 0; bottom: 0; width: 2px; margin-left: -1px;
    background: var(--green-primary); pointer-events: none; z-index: 2;
  }
  .strip__playhead b {
    position: absolute; top: -18px; left: 0; white-space: nowrap;
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.02em;
    color: #fff; background: var(--green-primary);
    border-radius: 999px; padding: 1px 7px;
  }
  .strip__op {
    margin: 0.55rem 0 0.25rem; font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted);
  }
  .strip__lanes { position: relative; }
  .strip__bar {
    position: absolute; height: 18px; border: 0; border-radius: 5px;
    font: 600 0.72rem/18px var(--font-body, inherit); text-align: left;
    padding: 0 0 0 7px; white-space: nowrap; overflow: hidden;
    cursor: pointer; min-width: 14px;
  }
  .strip__nights { font-weight: 500; opacity: 0.75; }
  .strip__dot {
    position: absolute; width: 12px; height: 12px; border: 0; border-radius: 3px;
    transform: rotate(45deg) translateX(-50%); cursor: pointer; padding: 0;
  }
  .strip--active { outline: 2px solid var(--green-primary); outline-offset: 1px; }

  .strip__scrub {
    display: block; width: 100%; margin: 8px 0 0; height: 30px;
    -webkit-appearance: none; appearance: none; background: transparent;
    cursor: grab;
  }
  .strip__scrub:active { cursor: grabbing; }
  .strip__scrub::-webkit-slider-runnable-track {
    height: 6px; border-radius: 999px; background: rgba(45, 106, 79, 0.16);
  }
  .strip__scrub::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 38px; height: 24px; margin-top: -9px; border-radius: 999px;
    background-color: var(--green-primary); border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.28);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.85)),
      linear-gradient(rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.85)),
      linear-gradient(rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.85));
    background-size: 2px 10px; background-repeat: no-repeat;
    background-position: calc(50% - 5px) center, 50% center, calc(50% + 5px) center;
  }
  .strip__scrub::-moz-range-track {
    height: 6px; border-radius: 999px; background: rgba(45, 106, 79, 0.16);
  }
  .strip__scrub::-moz-range-thumb {
    width: 38px; height: 24px; border-radius: 999px;
    background-color: var(--green-primary); border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.28);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.85)),
      linear-gradient(rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.85)),
      linear-gradient(rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.85));
    background-size: 2px 10px; background-repeat: no-repeat;
    background-position: calc(50% - 5px) center, 50% center, calc(50% + 5px) center;
  }

  .strip__bar--celebration { background: #F5B800; color: #3a2900; }
  .strip__bar--festival { background: #7C3AED; color: #fff; }
  .strip__bar--food_festival { background: #A78BFA; color: #fff; }
  .strip__bar--spectacular { background: #F97316; color: #fff; }
  .strip__bar--concert_series { background: #C2185B; color: #fff; }
  .strip__bar--passholder_event { background: #52B788; color: #fff; }
  .strip__bar--hard_ticket_event { background: #2563EB; color: #fff; }
  .strip__bar--ride_event { background: #3D9DD9; color: #fff; }
  .strip__bar--race_weekend { background: #E55934; color: #fff; }
  .strip__bar--closure { background: #6B7280; color: #fff; }
  .strip__dot--celebration { background: #F5B800; }
  .strip__dot--festival { background: #7C3AED; }
  .strip__dot--food_festival { background: #A78BFA; }
  .strip__dot--spectacular { background: #F97316; }
  .strip__dot--concert_series { background: #C2185B; }
  .strip__dot--passholder_event { background: #52B788; }
  .strip__dot--hard_ticket_event { background: #2563EB; }
  .strip__dot--ride_event { background: #3D9DD9; }
  .strip__dot--race_weekend { background: #E55934; }
  .strip__dot--closure { background: #6B7280; }

  .strip__day {
    margin-top: 1rem; border: 1px solid rgba(45, 106, 79, 0.14);
    border-radius: var(--radius-sm); padding: 0.8rem 1rem 0.9rem;
    background: rgba(45, 106, 79, 0.03);
  }
  .strip__day .strip__dayhead {
    margin: 0 0 0.5rem !important; font-size: 0.92rem !important;
    font-weight: 700; color: var(--green-primary) !important;
  }
  .strip__day .strip__dayrow {
    display: block; width: 100%; text-align: left;
    background: none; border: 0; margin: 0; padding: 0.35rem 0 0;
    font-family: inherit; font-size: 0.85rem; line-height: 1.55;
    color: var(--ink); cursor: pointer;
  }
  .strip__day .strip__dayrow .strip__swatch { margin-right: 7px; }
  .strip__day .strip__dayrow strong { font-weight: 700; color: var(--ink); }
  .strip__day .strip__dayrow > span { color: var(--muted); font-size: 0.8rem; margin-left: 6px; }
  .strip__day .strip__caret { font-style: normal; color: var(--muted); font-size: 0.7rem; margin-left: 6px; }
  .strip__day .strip__dayrow em {
    display: block; font-style: normal; margin: 0.3rem 0 0.15rem 18px;
    font-size: 0.8rem; color: var(--muted); line-height: 1.55;
  }
  .strip__day .strip__dayrow--off { opacity: 0.6; }
  .strip__day .strip__dayrow--off strong { font-weight: 500; }
  .strip__day .strip__dayquiet {
    margin: 0.35rem 0 0 !important; font-size: 0.85rem !important; color: var(--muted) !important;
  }
  .strip__day .strip__aged {
    margin: 0.6rem 0 0 !important; font-size: 0.78rem !important; color: var(--muted) !important;
  }

  .strip__legend {
    display: flex; flex-wrap: wrap; gap: 0.45rem 1rem;
    margin-top: 0.9rem; font-size: 0.78rem; color: var(--muted);
  }
  .strip__swatch {
    display: inline-block; width: 11px; height: 11px; border-radius: 3px; vertical-align: -1px;
    flex: none;
  }
  .strip__swatch--celebration { background: #F5B800; }
  .strip__swatch--festival { background: #7C3AED; }
  .strip__swatch--food_festival { background: #A78BFA; }
  .strip__swatch--spectacular { background: #F97316; }
  .strip__swatch--concert_series { background: #C2185B; }
  .strip__swatch--passholder_event { background: #52B788; }
  .strip__swatch--hard_ticket_event { background: #2563EB; }
  .strip__swatch--ride_event { background: #3D9DD9; }
  .strip__swatch--race_weekend { background: #E55934; }
  .strip__swatch--closure { background: #6B7280; }

</style>
