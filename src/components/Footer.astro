---
import { SITE } from '@/data/site';
import LanyardLogo from '@/components/LanyardLogo.astro';
const year = 2026;
---
<footer class="site-footer">
  <div class="site-footer__inner container">
    <div class="site-footer__brand">
      <LanyardLogo width={120} label="Lanyard" />
      <span class="site-footer__tagline">{SITE.tagline}</span>
    </div>
    <nav class="site-footer__links" aria-label="Footer">
      <a href="/calculator">Calculator</a>
      <a href="/guides">Guides</a>
      <a href="/beta">Join the beta</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="mailto:dan@lanyardpass.com">Contact</a>
    </nav>
    <p class="site-footer__legal">
      © {year} Lanyard LLC · Lanyard™ is a trademark of Lanyard LLC · An
      independent app, not affiliated with, endorsed by, or sponsored by any
      theme park operator.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--green-dark);
    color: var(--on-dark-muted);
    padding-block: 3rem 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .site-footer__inner { display: flex; flex-direction: column; gap: 1.25rem; }
  .site-footer__brand { display: flex; align-items: center; flex-wrap: wrap; gap: 0.75rem; }
  .site-footer__tagline { font-style: italic; font-size: 0.95rem; }
  .site-footer__links { display: flex; flex-wrap: wrap; gap: 1.4rem; }
  .site-footer__links a {
    color: var(--on-dark-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .site-footer__links a:hover { color: var(--green-accent); }
  .site-footer__legal { font-size: 0.82rem; color: rgba(207, 228, 216, 0.6); max-width: 90ch; }
</style>
