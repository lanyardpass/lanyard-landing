---
import { SITE, SOCIAL } from '@/data/site';
import LanyardLogo from '@/components/LanyardLogo.astro';
const year = 2026;
---
<footer class="site-footer">
  <div class="site-footer__inner container">
    <div class="site-footer__brand">
      <LanyardLogo width={120} label="Lanyard" />
      <span class="site-footer__tagline">{SITE.tagline}</span>
      {(SOCIAL.instagram || SOCIAL.bluesky) && (
        <div class="site-footer__social">
          {SOCIAL.instagram && (
            <a href={SOCIAL.instagram} aria-label="Lanyard on Instagram" rel="me noopener" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <rect x="2.5" y="2.5" width="19" height="19" rx="5.2" />
                <circle cx="12" cy="12" r="4.4" />
                <circle cx="17.4" cy="6.6" r="1.3" fill="currentColor" stroke="none" />
              </svg>
            </a>
          )}
          {SOCIAL.bluesky && (
            <a href={SOCIAL.bluesky} aria-label="Lanyard on Bluesky" rel="me noopener" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z" />
              </svg>
            </a>
          )}
        </div>
      )}
    </div>
    <nav class="site-footer__links" aria-label="Footer">
      <a href="/calculator">Calculator</a>
      <a href="/guides">Guides</a>
      <a href="/blockout-dates">Blockout dates</a>
      <a href="/blog">Blog</a>
      <a href="/details">The details</a>
      <a href="/about">About</a>
      <a href="/press">Press</a>
      <a href="/beta">Join the beta</a>
      <a href="/support">Support</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Use</a>
      <a href="mailto:dan@lanyardpass.com">Contact</a>
    </nav>
    <p class="site-footer__legal">
      <span>© {year} Lanyard LLC · Lanyard™ is a trademark of Lanyard LLC</span>
      <span>An independent app; the parks don’t endorse or sponsor it.</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--green-dark);
    color: var(--on-dark-muted);
    padding-block: 3rem 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .site-footer__inner { display: flex; flex-direction: column; gap: 1.25rem; }
  .site-footer__brand { display: flex; align-items: center; flex-wrap: wrap; gap: 0.75rem; }
  .site-footer__tagline { font-style: italic; font-size: 0.95rem; }
  .site-footer__social { display: flex; align-items: center; gap: 0.9rem; margin-left: auto; }
  .site-footer__social a { color: var(--on-dark-muted); line-height: 0; transition: color 0.15s ease; }
  .site-footer__social a:hover { color: var(--green-accent); }
  .site-footer__links { display: flex; flex-wrap: wrap; gap: 1.4rem; }
  .site-footer__links a {
    color: var(--on-dark-muted);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .site-footer__links a:hover { color: var(--green-accent); }
  .site-footer__legal { font-size: 0.82rem; color: rgba(207, 228, 216, 0.6); max-width: 90ch; }
  /* Each legal statement on its own line — a mid-clause wrap orphaning a word
     ("it.") reads as broken. Long lines still wrap within their statement. */
  .site-footer__legal span { display: block; }
  .site-footer__legal span + span { margin-top: 0.25rem; }
</style>
