---
import { COVERAGE } from '@/data/act3';
---
<section id="coverage" class="section section--dark cov">
  <div class="container">
    <header class="cov__head">
      <p class="kicker">Works with your pass</p>
      <h2 class="display cov__title">Whatever you hold, it’s covered.</h2>
      <p class="cov__lead">Tiers, park counts, resident pricing and home-park rules — modeled the way the operators actually sell them.</p>
    </header>
    <div class="cov__grid">
      {COVERAGE.map((c) => (
        <article class="cov__card">
          <h3 class="cov__op">{c.operator}</h3>
          <p class="cov__detail">{c.detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cov__head { margin-bottom: clamp(2rem, 5vw, 3rem); }
  /* Cap the measure on the title itself so `ch` scales with the big headline
     font (≈2 lines), not the small body font. */
  .cov__title { font-size: var(--fs-h2); margin-top: 0.6rem; max-width: 18ch; }
  .cov__lead { color: var(--on-dark-muted); font-size: var(--fs-lead); margin-top: 1rem; max-width: 46ch; }
  .cov__grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .cov__card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(82, 183, 136, 0.2);
    border-radius: var(--radius);
    padding: 1.6rem;
  }
  .cov__op { font-family: var(--font-display); font-weight: 800; font-size: 1.15rem; color: var(--green-accent); margin: 0 0 0.5rem; }
  .cov__detail { color: var(--on-dark-muted); font-size: 0.98rem; margin: 0; }
</style>
