---
import { CAPABILITIES } from '@/data/act3';
---
<section id="everything" class="section cap">
  <div class="container">
    <header class="cap__head">
      <p class="kicker">Everything it does</p>
      <h2 class="display cap__title">One app for the whole passholder life.</h2>
    </header>
    <ul class="cap__grid" role="list">
      {CAPABILITIES.map((c) => (
        <li class={`cap__card${c.soon || c.newIn ? ' cap__card--soon' : ''}`}>
          <span class="cap__icon" aria-hidden="true">{c.icon}</span>
          <div class="cap__text">
            <h3 class="cap__name">{c.title}</h3>
            <p class="cap__body">{c.body}</p>
          </div>
          {c.pro && <span class="cap__pro">Pro</span>}
          {c.soon && <span class="cap__soon">Coming soon</span>}
          {c.newIn && <span class="cap__new">New in {c.newIn}</span>}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* The cards deliberately echo the app's PerkRow: a white rounded card with a
     tinted square icon tile, title over description, and the badge as a
     top-right corner overlay. So the site previews the app's visual language
     before download. Proportions mirror PerkRow.swift (tile 36pt → 44px web,
     radius 14, shadow black-6%), scaled up for desktop reading distance. */
  .cap { background: var(--off-white); color: var(--ink); }
  .cap__head { margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .cap__title { font-size: var(--fs-h2); margin-top: 0.6rem; max-width: 18ch; }
  .cap__grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }
  .cap__card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    background: #fff;
    border: 1px solid rgba(20, 53, 42, 0.06);
    border-radius: var(--radius);
    padding: 1.05rem 1.1rem;
    box-shadow: var(--shadow-card);
  }
  /* Tinted square tile — the app's accent.opacity(0.15) over white, radius 8. */
  .cap__icon {
    flex: none;
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--green-accent) 15%, #fff);
    font-size: 1.35rem;
    line-height: 1;
  }
  .cap__text { min-width: 0; }
  .cap__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.02rem;
    line-height: 1.25;
    margin: 0.1rem 0 0.25rem;
    padding-right: 2.4rem; /* reserve for the corner Pro badge */
  }
  .cap__body { color: var(--muted); font-size: 0.9rem; line-height: 1.4; margin: 0; }
  /* Coming-soon pill — same corner slot as Pro, but dashed and muted: the
     app's unwalked-house "stamp here" treatment, borrowed as "not yet". */
  .cap__soon {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    background: transparent;
    border: 1.5px dashed rgba(20, 53, 42, 0.28);
    padding: 0.18rem 0.5rem;
    border-radius: var(--pill);
  }
  /* Wider corner pill needs a wider title reserve on that card only.
     (Shared by Coming-soon and New-in cards — both wear wide pills.) */
  .cap__card--soon .cap__name { padding-right: 6.2rem; }

  /* New-in pill — solid accent, the loudest of the three corner badges:
     a just-shipped feature outranks Pro's tint and soon's dashes. */
  .cap__new {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--green-accent);
    padding: 0.18rem 0.5rem;
    border-radius: var(--pill);
  }

  /* Corner badge — maps to PerkRow's top-trailing state pill slot. */
  .cap__pro {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--green-primary);
    background: color-mix(in srgb, var(--green-accent) 18%, #fff);
    border: 1px solid color-mix(in srgb, var(--green-accent) 45%, transparent);
    padding: 0.18rem 0.5rem;
    border-radius: var(--pill);
  }
</style>
