---
// KenBurnsImage — a still that drifts with a slow Ken-Burns push. Used for the
// hero (kept a still, never video, so it never tanks LCP) and any section image
// that wants a touch of life. astro:assets handles responsive WebP/AVIF.
// Honors prefers-reduced-motion: the drift simply stops (clean static image).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  /** Disable the drift for a fully static image. */
  animate?: boolean;
  /** Passed to astro:assets so it can pick the right widths. */
  sizes?: string;
  widths?: number[];
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'auto';
  class?: string;
}
const {
  src,
  alt,
  animate = true,
  sizes = '(min-width: 960px) 700px, 100vw',
  widths = [480, 800, 1200, 1600, 2000],
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className,
} = Astro.props;
---
<div class:list={['kb', { 'kb--anim': animate }, className]}>
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={loading}
    fetchpriority={fetchpriority}
    class="kb__img"
  />
</div>

<style>
  .kb { overflow: hidden; width: 100%; height: 100%; }
  .kb__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .kb--anim .kb__img {
    transform-origin: 50% 45%;
    animation: kb-drift 26s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes kb-drift {
    from { transform: scale(1.02) translate3d(0, 0, 0); }
    to   { transform: scale(1.10) translate3d(-1.5%, -1.5%, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .kb--anim .kb__img { animation: none; transform: none; }
  }
</style>
