---
// LocalAside — a visually distinct "from a local" block for Dan's lived bits
// (the Helios Bar tip, the tale-of-two). Dark, so the insider voice pops out of
// the off-white article. Optional background image (e.g. the constellation
// ceiling) sits behind a scrim. Slot-based prose.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title?: string;
  /** Optional atmospheric background image. */
  bg?: ImageMetadata;
  bgAlt?: string;
}
const { title = 'From a local', bg, bgAlt = '' } = Astro.props;
---
<aside class:list={['local-aside', { 'local-aside--bg': !!bg }]}>
  {bg && (
    <Image
      src={bg}
      alt={bgAlt}
      widths={[480, 800, 1200, 1600]}
      sizes="(min-width: 960px) 700px, 100vw"
      loading="lazy"
      class="local-aside__bg"
    />
  )}
  <div class="local-aside__content">
    <p class="local-aside__kicker">
      <span class="local-aside__pin" aria-hidden="true">📍</span> {title}
    </p>
    <div class="local-aside__body"><slot /></div>
  </div>
</aside>

<style>
  .local-aside {
    position: relative; overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--dark-gradient); color: var(--on-dark);
    margin: 2.2rem 0;
    box-shadow: var(--shadow-card);
  }
  .local-aside__bg {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; opacity: 0.22; filter: saturate(1.1);
  }
  .local-aside__content {
    position: relative; z-index: 1;
    padding: clamp(1.4rem, 4vw, 2rem) clamp(1.4rem, 4vw, 2.1rem);
  }
  .local-aside__kicker {
    display: flex; align-items: center; gap: 0.5rem; margin: 0 0 0.7rem;
    font-family: var(--font-display); font-weight: 800; font-size: 0.74rem;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--green-accent);
  }
  .local-aside__body { line-height: 1.7; color: var(--on-dark); }
  .local-aside__body :global(> * + *) { margin-top: 0.9rem; }
  .local-aside__body :global(p) { margin: 0; }
  .local-aside__body :global(strong) { color: #fff; font-weight: 700; }
  .local-aside__body :global(em) { color: var(--on-dark-muted); }
  .local-aside__body :global(a) { color: var(--green-accent); text-underline-offset: 2px; }
</style>
