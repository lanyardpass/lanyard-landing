---
// InViewVideoLoop — a contained, muted, looping clip that autoplays only while
// in view (IntersectionObserver) and lazily (preload="none", so nothing loads
// until it's near the viewport). Poster shows until it plays. Reduced-motion or
// data-saver: the poster still is all you get — the video never autoplays.
// Used for the §3 fountain-show loop at the Helios Bar tip (MP4-only by design).
interface Props {
  src: string;
  poster: string;
  /** Describes the clip for assistive tech / when the poster stands in. */
  label: string;
  caption?: string;
  wide?: boolean;
}
const { src, poster, label, caption, wide = false } = Astro.props;
---
<figure class:list={['vloop', { 'vloop--wide': wide }]} data-reveal>
  <div class="vloop__frame">
    <video
      class="vloop__video"
      data-inview-video
      muted
      loop
      playsinline
      preload="none"
      poster={poster}
      aria-label={label}
    >
      <source src={src} type="video/mp4" />
    </video>
  </div>
  {caption && <figcaption class="vloop__cap">{caption}</figcaption>}
</figure>

<script>
  // Play in-view, pause out-of-view. Skip autoplay entirely under reduced-motion
  // or data-saver — the poster carries it. Never throws (autoplay can reject).
  const vids = Array.from(document.querySelectorAll<HTMLVideoElement>('[data-inview-video]'));
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const conn = (navigator as any).connection;
  const saveData = !!(conn && conn.saveData);

  if (vids.length && !reduce && !saveData) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          const v = e.target as HTMLVideoElement;
          if (e.isIntersecting) { v.play().catch(() => {}); }
          else { v.pause(); }
        }
      },
      { threshold: 0.35 }
    );
    vids.forEach((v) => io.observe(v));
  }
</script>

<style>
  .vloop { margin: 2.2rem 0; }
  .vloop__frame {
    overflow: hidden; border-radius: var(--radius);
    box-shadow: var(--shadow-card); background: var(--green-dark);
    aspect-ratio: 16 / 9;
  }
  .vloop__video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vloop__cap {
    margin-top: 0.6rem; font-size: 0.82rem; color: var(--muted);
    line-height: 1.5; text-align: center;
  }
  /* Wide banner: full-width (capped at --maxw, no scrollbar), sitting ABOVE the
     sticky TOC (z-index:1) so the TOC flows behind it while on screen. */
  .vloop--wide {
    position: relative;
    z-index: 2;
    width: min(100vw, var(--maxw));
    margin-inline: calc(50% - min(50vw, var(--maxw) / 2));
  }
  @media (max-width: 600px) {
    .vloop--wide .vloop__frame { border-radius: 0; }
  }

  .vloop[data-reveal] { opacity: 0; transform: translateY(14px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .vloop[data-reveal].is-in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .vloop[data-reveal] { opacity: 1; transform: none; transition: none; }
  }
</style>
