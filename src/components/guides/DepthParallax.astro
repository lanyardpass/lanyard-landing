---
// DepthParallax — a single photo given real 2.5D depth via a depth map.
//
// Modern approach (vs. cutting the photo into layers): one photo + one grayscale
// depth map, displaced per-pixel in a small WebGL fragment shader. Because depth
// is CONTINUOUS, there are no layer boundaries to expose, so none of the layer
// failure modes (fans / ghosts / holes) can happen. Near pixels (bright depth)
// shift more than far pixels (dark depth), driven by scroll + a subtle pointer
// parallax on desktop.
//
// Raw WebGL (no Three.js) to stay light: ~a few KB of script, two image files.
// Everything runs in the visitor's browser on their GPU — nothing server-side.
// Fallback: a plain <img> shows by default and stays if WebGL is unavailable, or
// under prefers-reduced-motion / data-saver. Depth map generated by Depth
// Anything V2 (see docs/guide-image-pipeline.md).
import type { ImageMetadata } from 'astro';

interface Props {
  /** Public URLs (served as static files) for the photo and its depth map. */
  src: string;
  depth: string;
  alt: string;
  caption?: string;
  wide?: boolean;
  ratio?: string;
}
const { src, depth, alt, caption, wide = false, ratio = '16 / 9' } = Astro.props;
---
<figure class:list={['dparallax', { 'dparallax--wide': wide }]} data-reveal>
  <div class="dparallax__frame" style={`aspect-ratio: ${ratio};`} data-depth-parallax data-src={src} data-depth={depth}>
    <img class="dparallax__fallback" src={src} alt={alt} loading="lazy" decoding="async" />
    <canvas class="dparallax__canvas" aria-hidden="true"></canvas>
  </div>
  {caption && <figcaption class="dparallax__cap">{caption}</figcaption>}
</figure>

<script>
  // ---- Minimal raw-WebGL depth-displacement parallax -----------------------
  const VERT = `attribute vec2 aPos; varying vec2 vUv;
    void main(){ vUv = aPos*0.5+0.5; gl_Position = vec4(aPos,0.0,1.0); }`;
  const FRAG = `precision highp float; varying vec2 vUv;
    uniform sampler2D uScene; uniform sampler2D uDepth;
    uniform vec2 uOffset; uniform float uZoom;
    void main(){
      vec2 uv = (vUv-0.5)/uZoom + 0.5;          // zoom-in margin for displacement
      float d = texture2D(uDepth, uv).r;        // 0 far .. 1 near
      vec2 suv = clamp(uv + uOffset*(d-0.4), 0.001, 0.999);
      gl_FragColor = texture2D(uScene, suv);
    }`;

  function compile(gl: WebGLRenderingContext, type: number, src: string) {
    const s = gl.createShader(type)!; gl.shaderSource(s, src); gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) throw new Error(gl.getShaderInfoLog(s) || 'shader');
    return s;
  }

  function loadTex(gl: WebGLRenderingContext, url: string): Promise<WebGLTexture> {
    return new Promise((resolve, reject) => {
      const img = new Image(); img.decoding = 'async';
      img.onload = () => {
        const t = gl.createTexture()!;
        gl.bindTexture(gl.TEXTURE_2D, t);
        gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, true);
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGB, gl.RGB, gl.UNSIGNED_BYTE, img);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
        resolve(t);
      };
      img.onerror = reject; img.src = url;
    });
  }

  async function init(frame: HTMLElement) {
    const canvas = frame.querySelector<HTMLCanvasElement>('.dparallax__canvas')!;
    const gl = canvas.getContext('webgl', { antialias: true, alpha: false });
    if (!gl) return; // no WebGL → fallback <img> stays

    const prog = gl.createProgram()!;
    gl.attachShader(prog, compile(gl, gl.VERTEX_SHADER, VERT));
    gl.attachShader(prog, compile(gl, gl.FRAGMENT_SHADER, FRAG));
    gl.linkProgram(prog); gl.useProgram(prog);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
    const aPos = gl.getAttribLocation(prog, 'aPos');
    gl.enableVertexAttribArray(aPos); gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

    const uOffset = gl.getUniformLocation(prog, 'uOffset');
    const uZoom = gl.getUniformLocation(prog, 'uZoom');
    gl.uniform1f(uZoom, 1.12); // margin so displacement near the frame edge doesn't hit the clamp

    let scene: WebGLTexture, dmap: WebGLTexture;
    try {
      [scene, dmap] = await Promise.all([
        loadTex(gl, frame.dataset.src!), loadTex(gl, frame.dataset.depth!),
      ]);
    } catch { return; } // load failed → fallback <img> stays
    gl.activeTexture(gl.TEXTURE0); gl.bindTexture(gl.TEXTURE_2D, scene);
    gl.uniform1i(gl.getUniformLocation(prog, 'uScene'), 0);
    gl.activeTexture(gl.TEXTURE1); gl.bindTexture(gl.TEXTURE_2D, dmap);
    gl.uniform1i(gl.getUniformLocation(prog, 'uDepth'), 1);

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const w = frame.clientWidth, h = frame.clientHeight;
      canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
      gl!.viewport(0, 0, canvas.width, canvas.height);
    }
    resize();
    frame.classList.add('is-gl'); // reveals the canvas over the <img>

    // Targets from scroll (vertical) + pointer (desktop). Eased for smoothness.
    let tx = 0, ty = 0, cx = 0, cy = 0;
    let ptrX = 0, ptrY = 0;
    const onMove = (e: PointerEvent) => {
      const r = frame.getBoundingClientRect();
      ptrX = Math.max(-1, Math.min(1, (e.clientX - (r.left + r.width / 2)) / (r.width / 2)));
      ptrY = Math.max(-1, Math.min(1, (e.clientY - (r.top + r.height / 2)) / (r.height / 2)));
    };
    const finePointer = window.matchMedia('(pointer: fine)').matches;
    if (finePointer) window.addEventListener('pointermove', onMove, { passive: true });

    let running = false, raf = 0;
    function frameLoop() {
      const r = frame.getBoundingClientRect();
      const scroll = 1 - 2 * ((r.top + r.height / 2) / window.innerHeight); // -1..1
      // Horizontal pointer is the smallest: it tears vertical depth edges most
      // (e.g. the right edge of a statue against the sky). Scroll stays the lead.
      tx = ptrX * 0.010;
      ty = scroll * 0.028 + ptrY * 0.008;
      cx += (tx - cx) * 0.08; cy += (ty - cy) * 0.08;
      gl!.uniform2f(uOffset, cx, cy);
      gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
      // keep going while in view (and a beat after, so easing settles)
      if (running) raf = requestAnimationFrame(frameLoop);
    }

    const io = new IntersectionObserver((es) => {
      for (const e of es) {
        if (e.isIntersecting && !running) { running = true; raf = requestAnimationFrame(frameLoop); }
        else if (!e.isIntersecting && running) { running = false; cancelAnimationFrame(raf); }
      }
    }, { rootMargin: '100px' });
    io.observe(frame);
    window.addEventListener('resize', resize, { passive: true });
  }

  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-depth-parallax]'));
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const conn = (navigator as any).connection;
  const saveData = !!(conn && conn.saveData);
  if (frames.length && !reduce && !saveData) {
    // Lazily init each banner only when it's near the viewport.
    const io = new IntersectionObserver((es, obs) => {
      for (const e of es) {
        if (e.isIntersecting) { obs.unobserve(e.target); init(e.target as HTMLElement); }
      }
    }, { rootMargin: '300px' });
    frames.forEach((f) => io.observe(f));
  }
</script>

<style>
  .dparallax { margin: 2.2rem 0; }
  .dparallax__frame {
    position: relative; overflow: hidden;
    border-radius: var(--radius); box-shadow: var(--shadow-card);
    background: var(--green-dark);
  }
  .dparallax__fallback,
  .dparallax__canvas {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  /* Canvas hidden until WebGL is ready; then it fades in over the <img>. */
  .dparallax__canvas { opacity: 0; transition: opacity 0.4s ease; }
  .dparallax__frame.is-gl .dparallax__canvas { opacity: 1; }
  .dparallax__cap {
    margin-top: 0.6rem; font-size: 0.82rem; color: var(--muted);
    line-height: 1.5; text-align: center;
  }

  /* Full-bleed on mobile only (clears the sticky TOC on desktop — see GuideLayout). */
  @media (max-width: 959px) {
    .dparallax--wide { width: 100vw; margin-inline: calc(50% - 50vw); }
    .dparallax--wide .dparallax__frame { border-radius: 0; }
  }

  .dparallax[data-reveal] { opacity: 0; transform: translateY(14px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .dparallax[data-reveal].is-in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .dparallax[data-reveal] { opacity: 1; transform: none; transition: none; }
  }
</style>
