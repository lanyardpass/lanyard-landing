---
// LayeredParallax — a 3-plane depth banner from a single photo. Each plane
// drifts at its own rate as the reader scrolls, so near things move more than
// far, giving real depth (vs. one flat plane sliding).
//
// Built for Isle of Berk, with the planes pre-separated (see the asset pipeline):
//   front  = the Viking statues (clean cutout)
//   mid    = village + mountain, sky removed, statues painted out behind them
//   back   = a smooth sky plane that fills everything behind
//
// Why it stays clean (the artifact rules learned the hard way):
//   • No plane except `front` contains the statues, so there is no blurred-statue
//     "ghost" trailing the sharp one.
//   • Motion is DOWNWARD only, so the gap a receding plane opens is always at the
//     TOP — where the sky belongs — never a hole at the bottom.
//   • At a plane's rest (entering the viewport) translate is 0, so the full,
//     un-cropped image is what you first see.
//   • `front` barely separates from `mid` (subtle statue pop); the real depth is
//     the village receding against the near-static sky.
//
// Scroll-driven only (no gyroscope → no permission prompt). prefers-reduced-
// motion: planes sit still and read as the original composite.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  back: ImageMetadata;  // sky plane
  mid: ImageMetadata;   // village + mountain (sky removed, statues painted out)
  front: ImageMetadata; // statues
  alt: string;
  caption?: string;
  wide?: boolean;
  ratio?: string;
}
const { back, mid, front, alt, caption, wide = false, ratio = '16 / 9' } = Astro.props;
const sizes = wide ? '100vw' : '(min-width: 960px) 700px, 100vw';
const widths = [600, 900, 1200, 1700];
---
<figure class:list={['lparallax', { 'lparallax--wide': wide }]} data-reveal>
  <div class="lparallax__frame" style={`aspect-ratio: ${ratio};`} data-lparallax>
    <Image src={back} alt="" aria-hidden="true" widths={widths} sizes={sizes} loading="lazy" class="lparallax__layer lparallax__layer--bg" data-depth="0.12" />
    <Image src={mid} alt="" aria-hidden="true" widths={widths} sizes={sizes} loading="lazy" class="lparallax__layer" data-depth="0.62" />
    <Image src={front} alt={alt} widths={widths} sizes={sizes} loading="lazy" class="lparallax__layer" data-depth="0.9" />
  </div>
  {caption && <figcaption class="lparallax__cap">{caption}</figcaption>}
</figure>

<script>
  // One rAF loop drives every [data-lparallax]. Each plane's translateY tracks
  // the frame's progress through the viewport (0 entering → 1 exiting), scaled by
  // its data-depth — downward only, so opened gaps stay at the top (= sky).
  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-lparallax]'));
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (frames.length && !reduce) {
    const items = frames.map((frame) => ({
      frame,
      layers: Array.from(frame.querySelectorAll<HTMLElement>('.lparallax__layer')).map((el) => ({
        el,
        depth: parseFloat(el.dataset.depth || '0'),
      })),
    }));
    let ticking = false;
    const update = () => {
      ticking = false;
      const vh = window.innerHeight;
      for (const it of items) {
        const r = it.frame.getBoundingClientRect();
        if (r.bottom < -80 || r.top > vh + 80) continue;
        // 0 as the frame enters from the bottom → 1 as it exits the top.
        const t = Math.min(1, Math.max(0, (vh - r.top) / (vh + r.height)));
        const range = r.height * 0.11; // travel of the nearest plane
        for (const { el, depth } of it.layers) {
          el.style.transform = `translate3d(0, ${(depth * range * t).toFixed(1)}px, 0)`;
        }
      }
    };
    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>

<style>
  .lparallax { margin: 2.2rem 0; }
  .lparallax__frame {
    position: relative; overflow: hidden;
    border-radius: var(--radius); box-shadow: var(--shadow-card);
    background: var(--green-dark);
  }
  .lparallax__layer {
    position: absolute; left: 0; top: 0; width: 100%; height: 100%;
    object-fit: cover; display: block; will-change: transform;
  }
  /* The sky plane overscans so its own slight drift never exposes a frame edge;
     it's all sky, so any cropped region is still sky. */
  .lparallax__layer--bg { top: -15%; height: 130%; }
  .lparallax__cap {
    margin-top: 0.6rem; font-size: 0.82rem; color: var(--muted);
    line-height: 1.5; text-align: center;
  }

  /* Full-bleed on mobile only. On desktop a full-viewport breakout would slide
     under the sticky TOC rail (see GuideLayout), so it stays in the column. */
  @media (max-width: 959px) {
    .lparallax--wide { width: 100vw; margin-inline: calc(50% - 50vw); }
    .lparallax--wide .lparallax__frame { border-radius: 0; }
  }

  .lparallax[data-reveal] { opacity: 0; transform: translateY(14px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .lparallax[data-reveal].is-in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .lparallax[data-reveal] { opacity: 1; transform: none; transition: none; }
    .lparallax__layer { transform: none !important; }
  }
</style>
